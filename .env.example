# 蓝湖 MCP 服务器配置示例
# 复制此文件为 .env 并填入你的配置值
# ⚠️ 注意：不要将 .env 文件提交到 git！

# ==============================================
# 必需配置
# ==============================================

# 蓝湖 Cookie（必需）
# 获取方法：登录蓝湖网页版，打开浏览器开发者工具，从请求头中复制 Cookie
LANHU_COOKIE="PASSPORT=5Y5MU3GQLN2XSYEZLASECF2AOJEUJE2SFWE7HLTYMJDD4HVG3Y2CUZTKQY3PBMLEMNSRVGQTIL5BB276IDKSLOOVEFOK6ZDOJZUDQIY.6D81C1A9EB090DB6D0142CDB67ED94422E1CF355; _bl_uid=LXmw1qpX96C6bv2L6vbqej5r2ez2; aliyungf_tc=b690b6fe8d345caef7ce7eef69aad81d57856feb2edcb475ff0c37fff37fc9fe; user_token=eyJhbGciOiJIUzI1NiIsImlhdCI6MTc4MTE2MjM1NSwiZXhwIjoxNzg4OTM4MzU1fQ.eyJpZCI6IjIwOTk4M2Y2LTAyNDQtNDI4ZC05MWJkLWVhOTNkOTQzNzMwNyJ9.geHQIzBDwKDoZUMdN49aVCW9AEmD_4dAqiTTp91qMBA; Hm_lvt_529abdb47af362f96a25e19c9614ac7c=1780658487,1780660882,1781060207,1782717656; HMACCOUNT=20D0974EC00A2583; Hm_lpvt_529abdb47af362f96a25e19c9614ac7c=1782717661; acw_tc=12845e6517827855132881092f3c8f28f8f08d720ae5996be46142d095a025; session=.eJyNkEtuHDEMRO_SazcgfiRKc5kGxY89sD0e9IyRRZC7R4EvkCUXj_Wqfm9HnvF42y6pH4942Y6rb5etiUEDm1y9ZCrPYo5UCEyCI1PcYUApkOxBDftQJWxQqSuxxLTpaDgTimIuqkiVhuAaWMiMVJKhj2jOirw-TJpGiAahNGRbIvc4P_UWt-d2eZ7fS-3j6_V6O-wt7H3HMkanbHtB5p2x-z5g-h46yAeTUJHVY0xGdZkNFBChriRFETG04MblOA6QDtCQaiVaZ1Jhd8zqbqmloxcJGzrZydNymd1_-ZHX22uc9_P6T2_r0UlLWBYaFDJg9OZj8Mgi6aQLep5q8TOukrdpKjutUXfWmftQxF1L1hkAVYAW8f2I8wf4r7J__gKP7YE0.HSS3bA.JIzJo7tY5B-nvgE7oiellGtFPfU; SERVERID=d1d445c508d7833458b75ffe46239380|1782785517|1782785513"

# ==============================================
# 可选配置
# ==============================================

# 数据存储目录
# 默认值：./data
DATA_DIR="./data"

# 服务器主机地址
# 默认值：0.0.0.0（监听所有网络接口）
# 如果只需本地访问，使用 127.0.0.1
SERVER_HOST="0.0.0.0"

# 服务器端口
# 默认值：8000
SERVER_PORT=8000

# ==============================================
# 飞书机器人配置（可选）
# ==============================================

# 飞书 Webhook URL
# 获取方法：在飞书管理后台创建机器人后获取
# 留空则禁用飞书通知功能
FEISHU_WEBHOOK_URL=""

# ==============================================
# 高级配置
# ==============================================

# 日志级别
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
# 默认值：INFO
LOG_LEVEL="INFO"

# 日志目录
# 默认值：./logs
LOG_DIR="./logs"

# 缓存过期时间（秒）
# 缓存多久后检查是否需要更新
# 默认值：3600（1小时）
# 设为 0 则禁用缓存过期检查
CACHE_TTL=3600

# 最大并发下载数
# 默认值：5
MAX_CONCURRENT_DOWNLOADS=5

# HTTP 请求超时时间（秒）
# 默认值：30
HTTP_TIMEOUT=30

# 截图视口宽度
# 默认值：1920
SCREENSHOT_WIDTH=1920

# 截图视口高度
# 默认值：1080
SCREENSHOT_HEIGHT=1080

# ==============================================
# 开发配置
# ==============================================

# 调试模式
# 设为 "true" 启用调试模式
# 默认值：false
DEBUG="false"

# 启用热重载
# 设为 "true" 在开发时启用热重载
# 默认值：false
HOT_RELOAD="false"

# ==============================================
# 使用说明
# ==============================================
#
# 1. Cookie 安全：
#    - 妥善保管你的 LANHU_COOKIE
#    - 不要将 .env 文件提交到 git
#    - 定期更换 Cookie
#
# 2. 飞书集成：
#    - 可选但推荐用于团队协作
#    - 在飞书管理后台创建机器人
#    - 将机器人添加到群聊
#    - 复制 Webhook URL 到此处
#
# 3. 性能调优：
#    - 提高 MAX_CONCURRENT_DOWNLOADS 可加快批量操作速度
#    - 根据文档更新频率调整 CACHE_TTL
#    - 网络较慢时增加 HTTP_TIMEOUT
#
# 4. Docker 部署：
#    - 这些环境变量可通过 docker run -e 传递
#    - 或使用 docker-compose.yml 的 environment 配置
#
